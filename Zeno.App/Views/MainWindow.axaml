<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Zeno.App.ViewModels"
        x:Class="Zeno.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Zeno"
        Width="1100" Height="720"
        MinWidth="860" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ZenoBgPrimary}">

  <Grid ColumnDefinitions="220,*">

    <!-- Sidebar -->
    <Border Grid.Column="0"
            Background="{DynamicResource ZenoBgSidebar}"
            BorderBrush="{DynamicResource ZenoBorderSubtle}"
            BorderThickness="0,0,1,0">
      <DockPanel>

        <!-- Logo -->
        <StackPanel DockPanel.Dock="Top" Margin="20,28,20,24"
                    Orientation="Horizontal" Spacing="10">
          <Border Width="28" Height="28" CornerRadius="8"
                  Background="{DynamicResource ZenoAccent}">
            <TextBlock Text="Z" FontSize="15" FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="ZENO" FontSize="16" FontWeight="SemiBold"
                     Foreground="{DynamicResource ZenoTextPrimary}"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Nav -->
        <StackPanel DockPanel.Dock="Top" Margin="12,0" Spacing="2">

          <Button Command="{Binding NavigateCommand}" CommandParameter="Hoje"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  BorderThickness="0" Padding="12,10" CornerRadius="8"
                  Background="{Binding TodayBg}">
            <TextBlock Text="Hoje" FontSize="13" Foreground="{Binding TodayFg}"/>
          </Button>

          <Button Command="{Binding NavigateCommand}" CommandParameter="Próximos"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Background="Transparent" BorderThickness="0"
                  Padding="12,10" CornerRadius="8">
            <TextBlock Text="Próximos" FontSize="13"
                       Foreground="{DynamicResource ZenoTextSecondary}"/>
          </Button>

          <Button Command="{Binding NavigateCommand}" CommandParameter="Calendário"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Background="Transparent" BorderThickness="0"
                  Padding="12,10" CornerRadius="8">
            <TextBlock Text="Calendário" FontSize="13"
                       Foreground="{DynamicResource ZenoTextSecondary}"/>
          </Button>

          <Button Command="{Binding NavigateCommand}" CommandParameter="Projetos"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  BorderThickness="0" Padding="12,10" CornerRadius="8"
                  Background="{Binding ProjectsBg}">
            <TextBlock Text="Projetos" FontSize="13" Foreground="{Binding ProjectsFg}"/>
          </Button>

          <Separator Background="{DynamicResource ZenoBorderSubtle}" Margin="12,6"/>

          <Button Command="{Binding NavigateCommand}" CommandParameter="Pomodoro"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  BorderThickness="0" Padding="12,10" CornerRadius="8"
                  Background="{Binding PomodorooBg}">
            <TextBlock Text="Pomodoro" FontSize="13" Foreground="{Binding PomodoroFg}"/>
          </Button>

          <Button Command="{Binding NavigateCommand}" CommandParameter="Hidratação"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  BorderThickness="0" Padding="12,10" CornerRadius="8"
                  Background="{Binding WaterBg}">
            <TextBlock Text="Hidratação" FontSize="13" Foreground="{Binding WaterFg}"/>
          </Button>

        </StackPanel>

        <!-- Rodapé -->
        <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,20" Spacing="2">
          <Separator Background="{DynamicResource ZenoBorderSubtle}" Margin="0,0,0,8"/>
          <Button Command="{Binding NavigateCommand}" CommandParameter="Configurações"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Background="Transparent" BorderThickness="0"
                  Padding="12,10" CornerRadius="8">
            <TextBlock Text="Configurações" FontSize="13"
                       Foreground="{DynamicResource ZenoTextTertiary}"/>
          </Button>
        </StackPanel>

      </DockPanel>
    </Border>

    <!-- Content -->
    <DockPanel Grid.Column="1">

      <!-- Top bar -->
      <Border DockPanel.Dock="Top"
              Background="{DynamicResource ZenoBgPrimary}"
              BorderBrush="{DynamicResource ZenoBorderSubtle}"
              BorderThickness="0,0,0,1"
              Padding="28,16">
        <StackPanel>
          <TextBlock FontSize="22" FontWeight="SemiBold"
                     Foreground="{DynamicResource ZenoTextPrimary}">
            <Run Text="{Binding Greeting}"/><Run Text=", Bruno! 👋"/>
          </TextBlock>
          <TextBlock FontSize="13"
                     Foreground="{DynamicResource ZenoTextSecondary}"
                     Margin="0,2,0,0"
                     Text="{Binding CurrentPage}"/>
        </StackPanel>
      </Border>

      <!-- Page atual -->
      <ContentControl Content="{Binding CurrentView}"/>

    </DockPanel>

  </Grid>
</Window>
