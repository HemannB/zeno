<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Zeno.App.ViewModels"
        x:Class="Zeno.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Zeno"
        Width="1100" Height="720"
        MinWidth="860" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ZenoBgPrimary}">

  <Grid ColumnDefinitions="220,*">

    <!-- Sidebar -->
    <Border Grid.Column="0"
            Background="{DynamicResource ZenoBgSidebar}"
            BorderBrush="{DynamicResource ZenoBorderSubtle}"
            BorderThickness="0,0,1,0">
      <DockPanel>

        <!-- Logo -->
        <StackPanel DockPanel.Dock="Top" Margin="20,28,20,24" Orientation="Horizontal" Spacing="10">
          <Border Width="28" Height="28" CornerRadius="8"
                  Background="{DynamicResource ZenoAccent}">
            <TextBlock Text="Z" FontSize="15" FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="ZENO" FontSize="16" FontWeight="SemiBold"
                     Foreground="{DynamicResource ZenoTextPrimary}"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Nav items -->
        <StackPanel DockPanel.Dock="Top" Margin="12,0" Spacing="2">

          <Button Command="{Binding NavigateCommand}" CommandParameter="Hoje"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Background="Transparent" BorderThickness="0"
                  Padding="12,10" CornerRadius="8">
            <TextBlock Text="Hoje" Foreground="{DynamicResource ZenoTextPrimary}" FontSize="13"/>
          </Button>

          <Button Command="{Binding NavigateCommand}" CommandParameter="Próximos"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Background="Transparent" BorderThickness="0"
                  Padding="12,10" CornerRadius="8">
            <TextBlock Text="Próximos" Foreground="{DynamicResource ZenoTextSecondary}" FontSize="13"/>
          </Button>

          <Button Command="{Binding NavigateCommand}" CommandParameter="Calendário"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Background="Transparent" BorderThickness="0"
                  Padding="12,10" CornerRadius="8">
            <TextBlock Text="Calendário" Foreground="{DynamicResource ZenoTextSecondary}" FontSize="13"/>
          </Button>

          <Button Command="{Binding NavigateCommand}" CommandParameter="Projetos"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Background="Transparent" BorderThickness="0"
                  Padding="12,10" CornerRadius="8">
            <TextBlock Text="Projetos" Foreground="{DynamicResource ZenoTextSecondary}" FontSize="13"/>
          </Button>

        </StackPanel>

        <!-- Configurações no rodapé -->
        <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,20" Spacing="2">
          <Separator Background="{DynamicResource ZenoBorderSubtle}" Margin="0,0,0,8"/>
          <Button Command="{Binding NavigateCommand}" CommandParameter="Configurações"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Background="Transparent" BorderThickness="0"
                  Padding="12,10" CornerRadius="8">
            <TextBlock Text="Configurações" Foreground="{DynamicResource ZenoTextTertiary}" FontSize="13"/>
          </Button>
        </StackPanel>

      </DockPanel>
    </Border>

    <!-- Content area -->
    <DockPanel Grid.Column="1">

      <!-- Top bar -->
      <Border DockPanel.Dock="Top"
              Background="{DynamicResource ZenoBgPrimary}"
              BorderBrush="{DynamicResource ZenoBorderSubtle}"
              BorderThickness="0,0,0,1"
              Padding="28,16">
        <StackPanel>
          <TextBlock FontSize="22" FontWeight="SemiBold"
                     Foreground="{DynamicResource ZenoTextPrimary}">
            <Run Text="{Binding Greeting}"/><Run Text=", Bruno! 👋"/>
          </TextBlock>
          <TextBlock FontSize="13" Foreground="{DynamicResource ZenoTextSecondary}" Margin="0,2,0,0"
                     Text="{Binding CurrentPage}"/>
        </StackPanel>
      </Border>

      <!-- Page placeholder -->
      <Border Background="{DynamicResource ZenoBgPrimary}" Padding="28">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
          <TextBlock Text="ZENO" FontSize="64" FontWeight="Light"
                     Foreground="{DynamicResource ZenoAccent}"
                     HorizontalAlignment="Center" Opacity="0.08"/>
          <TextBlock Text="Foco sem ruído." FontSize="14"
                     Foreground="{DynamicResource ZenoTextTertiary}"
                     HorizontalAlignment="Center"/>
        </StackPanel>
      </Border>

    </DockPanel>

  </Grid>
</Window>
