<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Zeno.App.ViewModels"
             x:Class="Zeno.App.Views.WaterView"
             x:DataType="vm:WaterViewModel">

  <DockPanel>

    <Border DockPanel.Dock="Top" Padding="28,24,28,0">
      <StackPanel>
        <TextBlock Text="Hidratação"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource ZenoTextPrimary}"/>
        <TextBlock Text="Acompanhe sua ingestão de água diária"
                   FontSize="13"
                   Foreground="{DynamicResource ZenoTextSecondary}"
                   Margin="0,2,0,0"/>
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Bottom" Padding="28,0,28,28">
      <StackPanel Spacing="16">

        <Border Background="{DynamicResource ZenoBgSecondary}"
                BorderBrush="{DynamicResource ZenoBorderSubtle}"
                BorderThickness="1" CornerRadius="10"
                Padding="16,12">
          <StackPanel Spacing="6">
            <TextBlock Text="❝" FontSize="18"
                       Foreground="{DynamicResource ZenoAccent}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding Quote}"
                       FontSize="13" FontStyle="Italic"
                       Foreground="{DynamicResource ZenoTextSecondary}"
                       TextWrapping="Wrap" LineHeight="20"
                       TextAlignment="Center"/>
          </StackPanel>
        </Border>

        <Border Background="{DynamicResource ZenoBgSecondary}"
                BorderBrush="{DynamicResource ZenoBorderDefault}"
                BorderThickness="1" CornerRadius="10"
                Padding="16,12">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0">
              <TextBlock Text="META DIÁRIA"
                         FontSize="10" FontWeight="SemiBold"
                         Foreground="{DynamicResource ZenoTextTertiary}"
                         LetterSpacing="1"/>
              <TextBlock FontSize="14"
                         Foreground="{DynamicResource ZenoTextPrimary}"
                         Margin="0,4,0,0">
                <Run Text="{Binding Goal}"/>
                <Run Text=" copos"/>
              </TextBlock>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
              <Button Command="{Binding SetGoalCommand}" CommandParameter="6"
                      Background="{DynamicResource ZenoBgTertiary}"
                      BorderThickness="0" CornerRadius="6"
                      Foreground="{DynamicResource ZenoTextSecondary}"
                      Padding="10,6" FontSize="12">6</Button>
              <Button Command="{Binding SetGoalCommand}" CommandParameter="8"
                      Background="{DynamicResource ZenoBgTertiary}"
                      BorderThickness="0" CornerRadius="6"
                      Foreground="{DynamicResource ZenoTextSecondary}"
                      Padding="10,6" FontSize="12">8</Button>
              <Button Command="{Binding SetGoalCommand}" CommandParameter="10"
                      Background="{DynamicResource ZenoBgTertiary}"
                      BorderThickness="0" CornerRadius="6"
                      Foreground="{DynamicResource ZenoTextSecondary}"
                      Padding="10,6" FontSize="12">10</Button>
            </StackPanel>
          </Grid>
        </Border>

        <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12">
          <Button Grid.Column="0"
                  Command="{Binding RemoveGlassCommand}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Background="{DynamicResource ZenoBgSecondary}"
                  BorderBrush="{DynamicResource ZenoBorderDefault}"
                  BorderThickness="1"
                  Foreground="{DynamicResource ZenoTextSecondary}"
                  CornerRadius="10" Padding="0,14"
                  FontSize="20">−</Button>
          <StackPanel Grid.Column="1" HorizontalAlignment="Center"
                      VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="{Binding Glasses}"
                       FontSize="36" FontWeight="SemiBold"
                       Foreground="{DynamicResource ZenoTextPrimary}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="copos" FontSize="12"
                       Foreground="{DynamicResource ZenoTextTertiary}"
                       HorizontalAlignment="Center"/>
          </StackPanel>
          <Button Grid.Column="2"
                  Command="{Binding AddGlassCommand}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Background="{DynamicResource ZenoInfo}"
                  Foreground="White"
                  CornerRadius="10" Padding="0,14"
                  FontSize="20">+</Button>
        </Grid>

      </StackPanel>
    </Border>

    <!-- Gauge — SolidColorBrush explícito no Stroke -->
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="32">
      <Canvas Width="260" Height="260" HorizontalAlignment="Center">

        <Ellipse Width="260" Height="260"
                 Stroke="{DynamicResource ZenoBgTertiary}"
                 StrokeThickness="12"
                 Fill="Transparent"/>

        <Path x:Name="WaterArc"
              StrokeThickness="12"
              StrokeLineCap="Round"
              Fill="Transparent"
              Canvas.Left="6" Canvas.Top="6">
          <Path.Stroke>
            <SolidColorBrush Color="#0EA5E9"/>
          </Path.Stroke>
        </Path>

        <StackPanel Canvas.Left="55" Canvas.Top="95" Width="150" Spacing="4">
          <TextBlock Text="{Binding StatusLabel}"
                     FontSize="15" FontWeight="Medium"
                     Foreground="{DynamicResource ZenoTextPrimary}"
                     HorizontalAlignment="Center"
                     TextWrapping="Wrap"
                     TextAlignment="Center"/>
          <TextBlock FontSize="13"
                     Foreground="{DynamicResource ZenoTextSecondary}"
                     HorizontalAlignment="Center">
            <Run Text="{Binding Progress, StringFormat={}{0:P0}}"/>
          </TextBlock>
        </StackPanel>

      </Canvas>
    </StackPanel>

  </DockPanel>
</UserControl>
