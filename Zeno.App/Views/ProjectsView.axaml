<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Zeno.App.ViewModels"
             x:Class="Zeno.App.Views.ProjectsView"
             x:DataType="vm:ProjectsViewModel">

  <DockPanel>

    <!-- Header -->
    <Border DockPanel.Dock="Top" Padding="28,24,28,0">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0">
          <TextBlock Text="Projetos"
                     FontSize="20" FontWeight="SemiBold"
                     Foreground="{DynamicResource ZenoTextPrimary}"/>
          <TextBlock Text="Organize suas tarefas por projeto"
                     FontSize="13"
                     Foreground="{DynamicResource ZenoTextSecondary}"
                     Margin="0,2,0,0"/>
        </StackPanel>
        <Button Grid.Column="1"
                Command="{Binding StartAddingCommand}"
                Background="{DynamicResource ZenoAccent}"
                Foreground="White"
                CornerRadius="8"
                Padding="14,8"
                FontSize="13"
                VerticalAlignment="Center">
          + Novo projeto
        </Button>
      </Grid>
    </Border>

    <!-- Formulário novo projeto -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding IsAdding}"
            Margin="28,16,28,0"
            Background="{DynamicResource ZenoBgSecondary}"
            BorderBrush="{DynamicResource ZenoBorderDefault}"
            BorderThickness="1" CornerRadius="10"
            Padding="16">
      <StackPanel Spacing="12">

        <TextBlock Text="NOVO PROJETO"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="{DynamicResource ZenoTextTertiary}"
                   LetterSpacing="1"/>

        <TextBox Text="{Binding NewProjectName}"
                 PlaceholderText="Nome do projeto..."
                 Background="{DynamicResource ZenoBgTertiary}"
                 BorderBrush="{DynamicResource ZenoBorderDefault}"
                 BorderThickness="1" CornerRadius="8"
                 Foreground="{DynamicResource ZenoTextPrimary}"
                 Padding="12,10" FontSize="14"/>

        <!-- Seletor de cor -->
        <StackPanel Spacing="6">
          <TextBlock Text="COR"
                     FontSize="10" FontWeight="SemiBold"
                     Foreground="{DynamicResource ZenoTextTertiary}"
                     LetterSpacing="1"/>
          <ItemsControl ItemsSource="{Binding AvailableColors}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="x:String">
                <Border Width="28" Height="28" CornerRadius="14"
                        Margin="4" Cursor="Hand">
                  <Border.Background>
                    <SolidColorBrush Color="{Binding}"/>
                  </Border.Background>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- Ações -->
        <Grid ColumnDefinitions="*,Auto,Auto" >
          <Button Grid.Column="1"
                  Command="{Binding CancelAddingCommand}"
                  Background="Transparent"
                  BorderBrush="{DynamicResource ZenoBorderDefault}"
                  BorderThickness="1"
                  Foreground="{DynamicResource ZenoTextSecondary}"
                  CornerRadius="8" Padding="14,8"
                  Margin="0,0,8,0" FontSize="13">
            Cancelar
          </Button>
          <Button Grid.Column="2"
                  Command="{Binding AddProjectCommand}"
                  Background="{DynamicResource ZenoAccent}"
                  Foreground="White"
                  CornerRadius="8" Padding="14,8"
                  FontSize="13">
            Criar
          </Button>
        </Grid>

      </StackPanel>
    </Border>

    <!-- Lista de projetos -->
    <ScrollViewer Margin="28,16,28,24" VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding Projects}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:ProjectItemViewModel">
            <Border Background="{DynamicResource ZenoBgSecondary}"
                    BorderBrush="{DynamicResource ZenoBorderSubtle}"
                    BorderThickness="1" CornerRadius="10"
                    Margin="0,0,0,6">
              <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="16,14">

                <!-- Dot de cor -->
                <Border Grid.Column="0"
                        Width="12" Height="12" CornerRadius="6"
                        VerticalAlignment="Center"
                        Margin="0,0,14,0">
                  <Border.Background>
                    <SolidColorBrush Color="{Binding Color}"/>
                  </Border.Background>
                </Border>

                <!-- Nome -->
                <TextBlock Grid.Column="1"
                           Text="{Binding Name}"
                           FontSize="14"
                           Foreground="{DynamicResource ZenoTextPrimary}"
                           VerticalAlignment="Center"/>

                <!-- Contador -->
                <Border Grid.Column="2"
                        Background="{DynamicResource ZenoBgTertiary}"
                        CornerRadius="10" Padding="8,3"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center">
                  <TextBlock FontSize="12"
                             Foreground="{DynamicResource ZenoTextSecondary}"
                             Text="{Binding Count}"/>
                </Border>

                <!-- Arquivar -->
                <Button Grid.Column="3"
                        Command="{Binding $parent[ItemsControl].((vm:ProjectsViewModel)DataContext).ArchiveCommand}"
                        CommandParameter="{Binding}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="6,4"
                        Foreground="{DynamicResource ZenoTextTertiary}"
                        FontSize="12"
                        VerticalAlignment="Center">
                  Arquivar
                </Button>

              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </DockPanel>
</UserControl>
