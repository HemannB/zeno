<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Zeno.App.ViewModels"
             x:Class="Zeno.App.Views.StatsView"
             x:DataType="vm:StatsViewModel">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="28,24,28,28" Spacing="16">

      <!-- Header -->
      <StackPanel Spacing="2">
        <TextBlock Text="Estatísticas"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource ZenoTextPrimary}"/>
        <TextBlock Text="{Binding WeekLabel}"
                   FontSize="13"
                   Foreground="{DynamicResource ZenoTextSecondary}"/>
      </StackPanel>

      <!-- Cards de resumo -->
      <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">

        <Border Grid.Column="0"
                Background="{DynamicResource ZenoBgSecondary}"
                BorderBrush="{DynamicResource ZenoBorderSubtle}"
                BorderThickness="1" CornerRadius="10"
                Padding="16,14">
          <StackPanel Spacing="4">
            <TextBlock Text="HOJE"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource ZenoTextTertiary}"
                       LetterSpacing="1"/>
            <TextBlock Text="{Binding CompletedToday}"
                       FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource ZenoAccent}"/>
            <TextBlock Text="tarefas concluídas"
                       FontSize="11"
                       Foreground="{DynamicResource ZenoTextTertiary}"/>
          </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="{DynamicResource ZenoBgSecondary}"
                BorderBrush="{DynamicResource ZenoBorderSubtle}"
                BorderThickness="1" CornerRadius="10"
                Padding="16,14">
          <StackPanel Spacing="4">
            <TextBlock Text="SEMANA"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource ZenoTextTertiary}"
                       LetterSpacing="1"/>
            <TextBlock Text="{Binding CompletedWeek}"
                       FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource ZenoSuccess}"/>
            <TextBlock Text="tarefas concluídas"
                       FontSize="11"
                       Foreground="{DynamicResource ZenoTextTertiary}"/>
          </StackPanel>
        </Border>

        <Border Grid.Column="2"
                Background="{DynamicResource ZenoBgSecondary}"
                BorderBrush="{DynamicResource ZenoBorderSubtle}"
                BorderThickness="1" CornerRadius="10"
                Padding="16,14">
          <StackPanel Spacing="4">
            <TextBlock Text="STREAK"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource ZenoTextTertiary}"
                       LetterSpacing="1"/>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="{Binding Streak}"
                         FontSize="28" FontWeight="SemiBold"
                         Foreground="{DynamicResource ZenoWarning}"/>
              <TextBlock Text="🔥"
                         FontSize="20"
                         VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="dias consecutivos"
                       FontSize="11"
                       Foreground="{DynamicResource ZenoTextTertiary}"/>
          </StackPanel>
        </Border>

        <Border Grid.Column="3"
                Background="{DynamicResource ZenoBgSecondary}"
                BorderBrush="{DynamicResource ZenoBorderSubtle}"
                BorderThickness="1" CornerRadius="10"
                Padding="16,14">
          <StackPanel Spacing="4">
            <TextBlock Text="POMODOROS"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource ZenoTextTertiary}"
                       LetterSpacing="1"/>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="{Binding PomodorosToday}"
                         FontSize="28" FontWeight="SemiBold"
                         Foreground="{DynamicResource ZenoDanger}"/>
              <TextBlock Text="🍅"
                         FontSize="20"
                         VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="sessões hoje"
                       FontSize="11"
                       Foreground="{DynamicResource ZenoTextTertiary}"/>
          </StackPanel>
        </Border>

      </Grid>

      <!-- Meta semanal -->
      <Border Background="{DynamicResource ZenoBgSecondary}"
              BorderBrush="{DynamicResource ZenoBorderSubtle}"
              BorderThickness="1" CornerRadius="10"
              Padding="20,16">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0">
              <TextBlock Text="META SEMANAL"
                         FontSize="10" FontWeight="SemiBold"
                         Foreground="{DynamicResource ZenoTextTertiary}"
                         LetterSpacing="1"/>
              <TextBlock FontSize="14"
                         Foreground="{DynamicResource ZenoTextPrimary}"
                         Margin="0,4,0,0">
                <Run Text="{Binding CompletedWeek}"/>
                <Run Text=" de "/>
                <Run Text="{Binding WeeklyGoal}"/>
                <Run Text=" tarefas"/>
              </TextBlock>
            </StackPanel>
            <TextBlock Grid.Column="1"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource ZenoAccent}"
                       VerticalAlignment="Center">
              <Run Text="{Binding WeeklyProgress, StringFormat={}{0:P0}}"/>
            </TextBlock>
          </Grid>

          <!-- Barra de progresso -->
          <Border Height="8" CornerRadius="4"
                  Background="{DynamicResource ZenoBgTertiary}">
            <Border CornerRadius="4"
                    Background="{DynamicResource ZenoAccent}"
                    HorizontalAlignment="Left"
                    Width="{Binding WeeklyProgress}"/>
          </Border>

        </StackPanel>
      </Border>

      <!-- Gráfico de barras — últimos 7 dias -->
      <Border Background="{DynamicResource ZenoBgSecondary}"
              BorderBrush="{DynamicResource ZenoBorderSubtle}"
              BorderThickness="1" CornerRadius="10"
              Padding="20,16">
        <StackPanel Spacing="12">

          <TextBlock Text="ÚLTIMOS 7 DIAS"
                     FontSize="10" FontWeight="SemiBold"
                     Foreground="{DynamicResource ZenoTextTertiary}"
                     LetterSpacing="1"/>

          <Grid Height="120">
            <ItemsControl ItemsSource="{Binding DaySats}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Rows="1"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:DayStatViewModel">
                  <StackPanel HorizontalAlignment="Center" Spacing="6"
                              VerticalAlignment="Bottom">

                    <TextBlock Text="{Binding Count}"
                               FontSize="11"
                               Foreground="{DynamicResource ZenoTextSecondary}"
                               HorizontalAlignment="Center"/>

                    <!-- Barra -->
                    <Border Width="28" CornerRadius="4"
                            Background="{DynamicResource ZenoAccent}"
                            VerticalAlignment="Bottom"
                            MinHeight="4">
                      <Border.Height>
                        <MultiBinding>
                          <Binding Path="Progress"/>
                        </MultiBinding>
                      </Border.Height>
                    </Border>

                    <TextBlock Text="{Binding Label}"
                               FontSize="10"
                               Foreground="{DynamicResource ZenoTextTertiary}"
                               HorizontalAlignment="Center"/>

                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Grid>

        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
